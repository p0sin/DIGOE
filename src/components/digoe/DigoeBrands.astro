---
const brands = [
  {
    name: 'DYMAX',
    slug: 'dymax',
    body: 'Líder global en adhesivos de curado rápido y sistemas de luz UV.',
    alt: 'Equipo Dymax industrial',
  },
  {
    name: 'PLASMATREAT',
    slug: 'plasmatreat',
    body: 'Tecnología de plasma atmosférico para el tratamiento de superficies.',
    alt: 'Tecnología Plasmatreat',
  },
  {
    name: 'JANOME',
    slug: 'janome',
    body: 'Robótica industrial de alta precisión y sistemas de automatización.',
    alt: 'Robótica Janome',
  },
] as const;
---

<section class="industrial-white-space bg-base-100" id="brands">
  <div class="container mx-auto px-8">
    <h2 class="text-headline-md mb-16 text-center">Tecnología de punta</h2>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        brands.map((b) => (
          <div class="group relative overflow-hidden bg-base-100">
            <div class="h-64 overflow-hidden">
              <img
                src={`/brands/${b.slug}.webp`}
                alt={b.alt}
                class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0"
                width="640"
                height="256"
                loading="lazy"
              />
            </div>
            <div class="border-t-4 border-primary p-8">
              <h3 class="mb-2 text-2xl font-black tracking-tighter">{b.name}</h3>
              <p class="mb-6 text-sm text-slate-600">{b.body}</p>
              <a
                class="border-b-2 border-primary pb-1 text-xs font-bold uppercase tracking-widest text-primary"
                href="#contact"
              >
                Ver catálogo
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
