---
import { getMessages } from '../../i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale).sectors;
---

<section class="industrial-white-space overflow-hidden bg-neutral text-neutral-content">
  <div class="container mx-auto px-8">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <span class="text-[0.6875rem] font-bold uppercase tracking-widest text-warning"
          >{t.kicker}</span
        >
        <h2 class="text-display-lg mt-4 mb-8 leading-tight max-sm:text-3xl">
          {t.titleLine1}
          <br />
          {t.titleLine2}
        </h2>
        <p class="mb-8 text-white/80">
          {t.intro}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:col-span-8">
        {
          t.items.map((s) => (
            <div
              class:list={[
                'group bg-white/5 p-12 transition-colors duration-500 hover:bg-accent',
                s.offset,
              ]}
            >
              <span class="material-symbols-outlined mb-6 text-4xl! text-warning" aria-hidden="true">
                {s.icon}
              </span>
              <h4 class="mb-4 text-xl font-bold uppercase tracking-tighter">{s.title}</h4>
              <div class="mb-4 h-px w-12 bg-warning transition-all duration-500 group-hover:w-full" />
              <p class="text-sm text-white/75 group-hover:text-white">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
