---
/*
  Technologies.astro
  ──────────────────
  Sección "Tecnología de punta" rediseñada sin imágenes de marca.
  Muestra las capacidades tecnológicas con iconografía SVG inline,
  una etiqueta de categoría, descripción y CTA a contacto.

  Personalización:
  - Edita el array TECHNOLOGIES para agregar/quitar tecnologías.
  - Ajusta `t.title` y `t.subtitle` en tus archivos de i18n.
  - El icono de cada item es SVG inline; reemplaza el `<svg>` por el que necesites.
  - Cambia `href` del CTA al hash de tu sección de contacto.

  Dependencias:
  - i18n helper `getMessages` y tipo `Locale`
  - `homeSectionHash` para el link de contacto
  - Tailwind CSS (clases utilitarias)

  Uso:
    import Technologies from '../components/sections/Technologies.astro';
    <Technologies locale={locale} />
*/

import { getMessages, homeSectionHash } from '../../i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale).technologies;

const TECHNOLOGIES = [
  {
    category: t.items[0]?.category ?? 'Adhesivos y curado',
    name: t.items[0]?.name ?? 'Curado rápido UV',
    body:
      t.items[0]?.body ??
      'Sistemas de adhesivos de alto rendimiento con curado por luz ultravioleta para uniones precisas y tiempos de ciclo reducidos.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="24" cy="24" r="8"/>
      <line x1="24" y1="6" x2="24" y2="10"/>
      <line x1="24" y1="38" x2="24" y2="42"/>
      <line x1="6" y1="24" x2="10" y2="24"/>
      <line x1="38" y1="24" x2="42" y2="24"/>
      <line x1="11.5" y1="11.5" x2="14.4" y2="14.4"/>
      <line x1="33.6" y1="33.6" x2="36.5" y2="36.5"/>
      <line x1="36.5" y1="11.5" x2="33.6" y2="14.4"/>
      <line x1="14.4" y1="33.6" x2="11.5" y2="36.5"/>
    </svg>`,
  },
  {
    category: t.items[1]?.category ?? 'Tratamiento de superficies',
    name: t.items[1]?.name ?? 'Plasma atmosférico',
    body:
      t.items[1]?.body ??
      'Activación y limpieza de superficies mediante plasma a presión atmosférica para mejorar la adherencia sin disolventes ni procesos húmedos.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 38 C16 38 10 30 14 22 C18 14 24 16 24 10 C24 16 30 14 34 22 C38 30 32 38 32 38"/>
      <path d="M20 38 C20 38 17 33 19 28 C21 23 24 24 24 20 C24 24 27 23 29 28 C31 33 28 38 28 38"/>
      <line x1="16" y1="38" x2="32" y2="38"/>
    </svg>`,
  },
  {
    category: t.items[2]?.category ?? 'Automatización',
    name: t.items[2]?.name ?? 'Robótica de precisión',
    body:
      t.items[2]?.body ??
      'Brazos robóticos y sistemas de automatización de alta exactitud para dispensado, ensamble y procesos repetitivos de manufactura.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="18" y="4" width="12" height="8" rx="2"/>
      <line x1="24" y1="12" x2="24" y2="18"/>
      <rect x="14" y="18" width="20" height="12" rx="2"/>
      <line x1="14" y1="22" x2="8" y2="22"/>
      <line x1="8" y1="18" x2="8" y2="32"/>
      <line x1="8" y1="32" x2="4" y2="36"/>
      <line x1="34" y1="22" x2="40" y2="22"/>
      <line x1="40" y1="18" x2="40" y2="32"/>
      <line x1="40" y1="32" x2="44" y2="36"/>
      <line x1="24" y1="30" x2="24" y2="38"/>
      <circle cx="24" cy="40" r="4"/>
    </svg>`,
  },
];
---

<section class="industrial-white-space bg-base-100" id="technologies">
  <div class="container mx-auto px-8">
    <div class="mb-16 text-center">
      <h2 class="text-headline-md">{t.title}</h2>
      {
        t.subtitle && (
          <p class="mx-auto mt-4 max-w-xl text-base text-slate-500">
            {t.subtitle}
          </p>
        )
      }
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        TECHNOLOGIES.map((tech) => (
          <div class="group flex flex-col border border-slate-200 bg-white transition-shadow duration-300 hover:shadow-md">
            <div class="flex items-center justify-center border-b border-slate-100 bg-slate-50 p-10">
              <div class="h-16 w-16 text-primary transition-transform duration-300 group-hover:scale-110">
                <Fragment set:html={tech.icon} />
              </div>
            </div>

            <div class="flex flex-1 flex-col p-8">
              <span class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary/70">
                {tech.category}
              </span>
              <h3 class="mb-3 text-xl font-black tracking-tight text-slate-900">
                {tech.name}
              </h3>
              <p class="mb-8 flex-1 text-sm leading-relaxed text-slate-600">
                {tech.body}
              </p>
              <a
                class="mt-auto w-fit border-b-2 border-primary pb-1 text-xs font-bold uppercase tracking-widest text-primary transition-opacity duration-200 hover:opacity-70"
                href={homeSectionHash(locale, 'contact')}
              >
                {t.ctaCatalog}
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
