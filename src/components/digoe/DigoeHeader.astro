---
import {
  alternatePageUrl,
  getMessages,
  homePath,
  homeSectionHash,
} from '../../i18n';
import type { Locale, PageContext } from '../../i18n/types';

interface Props {
  locale: Locale;
  page?: PageContext;
}

const { locale, page = 'home' } = Astro.props;
const t = getMessages(locale).header;
const nav = [
  { href: homeSectionHash(locale, 'services'), label: t.nav.services },
  { href: homeSectionHash(locale, 'technologies'), label: t.nav.technologies },
  { href: homeSectionHash(locale, 'about'), label: t.nav.about },
  { href: homeSectionHash(locale, 'contact'), label: t.nav.contact },
] as const;

const linkToEs = locale === 'en' ? alternatePageUrl('en', page) : null;
const linkToEn = locale === 'es' ? alternatePageUrl('es', page) : null;
---

<header
  class="fixed top-0 z-50 w-full rounded-none border-b border-base-300/80 bg-base-100/80 backdrop-blur-md dark:border-slate-700 dark:bg-slate-900/80"
>
  <div class="container mx-auto flex items-center justify-between px-8 py-4">
    <a
      href={homePath(locale)}
      class="flex items-center gap-3"
      aria-label={t.brand}
    >
      <span
        class="font-tradegothic text-xl font-bold tracking-tighter text-blue-700 dark:text-blue-600 sm:text-4xl"
        >{t.brand}</span
      >
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label={t.navLabel}>
      {
        nav.map((item) => (
          <a
            class="font-sans text-sm font-medium uppercase tracking-widest text-slate-600 transition-colors duration-200 hover:text-blue-700 dark:text-slate-400 dark:hover:text-blue-400"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <div class="dropdown dropdown-end md:hidden">
        <label
          tabindex="0"
          class="btn btn-ghost btn-square"
          aria-label={t.openMenu}
        >
          <span class="material-symbols-outlined text-2xl!">menu</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content menu rounded-box z-50 mt-2 w-52 border border-base-300 bg-base-100 p-2 shadow-lg"
        >
          {
            nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div
        class="flex items-center gap-1 font-sans text-sm font-bold uppercase tracking-tighter text-blue-700 dark:text-blue-500"
        role="group"
        aria-label="Language"
      >
        {
          locale === 'es' ? (
            <span
              class="rounded bg-blue-700/15 px-1.5 py-0.5 text-blue-800 dark:text-blue-400"
              aria-current="true"
            >
              {t.langEs}
            </span>
          ) : (
            <a
              href={linkToEs!}
              class="rounded px-1.5 py-0.5 transition-colors hover:bg-base-200 dark:hover:bg-slate-800"
            >
              {t.langEs}
            </a>
          )
        }
        <span class="text-slate-400" aria-hidden="true">|</span>
        {
          locale === 'en' ? (
            <span
              class="rounded bg-blue-700/15 px-1.5 py-0.5 text-blue-800 dark:text-blue-400"
              aria-current="true"
            >
              {t.langEn}
            </span>
          ) : (
            <a
              href={linkToEn!}
              class="rounded px-1.5 py-0.5 transition-colors hover:bg-base-200 dark:hover:bg-slate-800"
            >
              {t.langEn}
            </a>
          )
        }
      </div>
    </div>
  </div>
</header>
