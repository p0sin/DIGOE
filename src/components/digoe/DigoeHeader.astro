---
const nav = [
  { href: '#services', label: 'Servicios' },
  { href: '#brands', label: 'Marcas' },
  { href: '#about', label: 'Nosotros' },
  { href: '#contact', label: 'Contacto' },
] as const;

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'DIGOE GF';
---

<header
  class="fixed top-0 z-50 w-full rounded-none border-b border-base-300/80 bg-base-100/80 backdrop-blur-md dark:border-slate-700 dark:bg-slate-900/80"
>
  <div class="mx-auto flex w-full max-w-full items-center justify-between px-4 py-4 sm:px-8">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-3xl! text-blue-700 dark:text-blue-500" aria-hidden="true"
        >factory</span
      >
      <span
        class="font-sans text-xl font-black uppercase tracking-tighter text-blue-700 dark:text-blue-600 sm:text-2xl"
        >{siteName}</span
      >
    </div>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            class="font-sans text-sm font-medium uppercase tracking-widest text-slate-600 transition-colors duration-200 hover:text-blue-700 dark:text-slate-400 dark:hover:text-blue-400"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <div class="dropdown dropdown-end md:hidden">
        <label tabindex="0" class="btn btn-ghost btn-square" aria-label="Abrir menú">
          <span class="material-symbols-outlined text-2xl!">menu</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content menu rounded-box z-50 mt-2 w-52 border border-base-300 bg-base-100 p-2 shadow-lg"
        >
          {
            nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <button
        type="button"
        class="font-sans text-sm font-bold uppercase tracking-tighter text-blue-700 dark:text-blue-500"
      >
        ES | EN
      </button>
    </div>
  </div>
</header>
