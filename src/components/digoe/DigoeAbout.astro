---
import { getMessages } from '../../i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale).about;
---

<section class="industrial-white-space bg-base-100" id="about">
  <div class="container mx-auto px-8">
    <div class="grid grid-cols-1 gap-20 lg:grid-cols-2">
      <div>
        <span class="text-[0.6875rem] font-bold uppercase tracking-widest text-primary"
          >{t.kicker}</span
        >
        <h2 class="text-headline-md mt-4 mb-8">{t.title}</h2>
        <div class="space-y-6 leading-relaxed text-slate-600">
          <p>{t.p1}</p>
          <p>{t.p2}</p>
        </div>
        <div class="mt-12 grid grid-cols-3 gap-4">
          <div class="bg-base-200 p-6">
            <span class="block text-3xl font-black text-primary">14+</span>
            <span class="text-[0.6875rem] font-bold uppercase tracking-wider text-slate-600"
              >{t.statYears}</span
            >
          </div>
          <div class="bg-base-200 p-6">
            <span class="block text-3xl font-black text-primary">3</span>
            <span class="text-[0.6875rem] font-bold uppercase tracking-wider text-slate-600"
              >{t.statBrands}</span
            >
          </div>
          <div class="bg-base-200 p-6">
            <span class="block text-3xl font-black text-primary">100%</span>
            <span class="text-[0.6875rem] font-bold uppercase tracking-wider text-slate-600"
              >{t.statCoverage}</span
            >
          </div>
        </div>
      </div>
      <div class="flex flex-col justify-center bg-base-300 p-12">
        <h3 class="mb-6 flex items-center gap-3 text-xl font-bold">
          <span class="material-symbols-outlined text-primary" aria-hidden="true">rocket_launch</span>
          {t.missionTitle}
        </h3>
        <p class="mb-8 border-l-4 border-primary pl-6 italic text-slate-600">
          &ldquo;{t.missionQuote}&rdquo;
        </p>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-widest">{t.valuesTitle}</h4>
        <div class="flex flex-wrap gap-2">
          {
            t.values.map((v) => (
              <span class="border border-base-300/80 bg-base-100 px-4 py-2 text-[0.6875rem] font-bold uppercase">
                {v}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
