---
import { getMessages } from '../../i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale).contact;
const phone = import.meta.env.PUBLIC_PHONE ?? '33 3123 0189';
const email = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'arturopo97@gmail.com';
const location = import.meta.env.PUBLIC_PRIVACY_ADDRESS ?? 'Guadalajara, Jalisco, México';
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<section class="industrial-white-space bg-base-100" id="contact">
  <div class="container mx-auto px-8">
    <div class="bg-primary p-1 md:p-16">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">
        <div class="text-primary-content">
          <h2 class="text-display-lg mb-8 max-sm:text-3xl">{t.title}</h2>
          <div class="space-y-8">
            <div class="flex items-center gap-6">
              <span class="material-symbols-outlined text-3xl!" aria-hidden="true">phone_in_talk</span>
              <div>
                <span class="block text-[0.6875rem] font-bold uppercase tracking-widest opacity-70"
                  >{t.phone}</span
                >
                <span class="text-xl font-bold">{phone}</span>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <span class="material-symbols-outlined text-3xl!" aria-hidden="true">mail</span>
              <div>
                <span class="block text-[0.6875rem] font-bold uppercase tracking-widest opacity-70"
                  >{t.email}</span
                >
                <a class="text-xl font-bold hover:underline" href={`mailto:${email}`}>{email}</a>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <span class="material-symbols-outlined text-3xl!" aria-hidden="true">location_on</span>
              <div>
                <span class="block text-[0.6875rem] font-bold uppercase tracking-widest opacity-70"
                  >{t.location}</span
                >
                <span class="text-xl font-bold">{location}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-base-100 p-10 text-base-content">
          <form class="space-y-6" method="post" action="https://api.web3forms.com/submit">
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="Nuevo contacto desde DIGOE" />
            <input type="hidden" name="from_name" value="DIGOE GF" />
            <input
              type="hidden"
              name="redirect"
              value={
                locale === 'en'
                  ? 'https://digoegf.com/en/?contact=ok#contact'
                  : 'https://digoegf.com/?contact=ok#contact'
              }
            />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
              <div>
                <label class="mb-2 block text-[0.6875rem] font-bold uppercase" for="digoe-name"
                  >{t.formName}</label
                >
                <input
                  id="digoe-name"
                  name="name"
                  type="text"
                  placeholder={t.placeholderName}
                  class="w-full border-0 border-b-2 border-transparent bg-base-200 px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-0"
                />
              </div>
              <div>
                <label class="mb-2 block text-[0.6875rem] font-bold uppercase" for="digoe-company"
                  >{t.formCompany}</label
                >
                <input
                  id="digoe-company"
                  name="company"
                  type="text"
                  placeholder={t.placeholderCompany}
                  class="w-full border-0 border-b-2 border-transparent bg-base-200 px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-0"
                />
              </div>
            </div>
            <div>
              <label class="mb-2 block text-[0.6875rem] font-bold uppercase" for="digoe-email"
                >{t.formEmail}</label
              >
              <input
                id="digoe-email"
                name="email"
                type="email"
                placeholder={t.placeholderEmail}
                class="w-full border-0 border-b-2 border-transparent bg-base-200 px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-0"
              />
            </div>
            <div>
              <label class="mb-2 block text-[0.6875rem] font-bold uppercase" for="digoe-msg"
                >{t.formMessage}</label
              >
              <textarea
                id="digoe-msg"
                name="message"
                rows="4"
                placeholder={t.placeholderMessage}
                class="w-full border-0 border-b-2 border-transparent bg-base-200 px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-0"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-accent py-4 text-sm font-bold uppercase tracking-widest text-accent-content transition-colors hover:bg-primary"
            >
              {t.submit}
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
