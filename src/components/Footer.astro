---
import { getMessages, homeSectionHash, privacyPath } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'DIGOE GF';
const cofepris = import.meta.env.PUBLIC_COFEPRIS ?? '';
const t = getMessages(locale).footer;
---

<footer class="w-full rounded-none bg-slate-900 dark:bg-black">
  <div
    class="grid w-full grid-cols-1 gap-12 px-8 py-20 md:grid-cols-3 md:px-12"
  >
    <div>
      <span
        class="font-sans text-xl font-black uppercase tracking-tighter text-white"
        >{siteName}</span
      >
      <p
        class="mt-6 font-sans text-sm uppercase leading-relaxed tracking-widest text-slate-400"
      >
        {t.taglineLine1}
        <br />
        {t.taglineLine2}
      </p>
      <div class="mt-8 flex gap-4">
        <a
          class="text-slate-400 transition-all hover:text-blue-500"
          href="#"
          aria-label={t.shareAria}
        >
          <span class="material-symbols-outlined">share</span>
        </a>
        <a
          class="text-slate-400 transition-all hover:text-blue-500"
          href="#"
          aria-label={t.webAria}
        >
          <span class="material-symbols-outlined">language</span>
        </a>
      </div>
    </div>
    <div>
      <h4
        class="mb-8 font-sans text-sm font-bold uppercase tracking-widest text-white"
      >
        {t.navHeading}
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="font-sans text-sm uppercase tracking-widest text-slate-400 transition-all hover:text-blue-500"
            href={homeSectionHash(locale, 'services')}>{getMessages(locale).header.nav.services}</a
          >
        </li>
        <li>
          <a
            class="font-sans text-sm uppercase tracking-widest text-slate-400 transition-all hover:text-blue-500"
            href={homeSectionHash(locale, 'brands')}>{getMessages(locale).header.nav.brands}</a
          >
        </li>
        <li>
          <a
            class="font-sans text-sm uppercase tracking-widest text-slate-400 transition-all hover:text-blue-500"
            href={homeSectionHash(locale, 'about')}>{getMessages(locale).header.nav.about}</a
          >
        </li>
        <li>
          <a
            class="font-sans text-sm uppercase tracking-widest text-slate-400 transition-all hover:text-blue-500"
            href={homeSectionHash(locale, 'contact')}>{getMessages(locale).header.nav.contact}</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h4
        class="mb-8 font-sans text-sm font-bold uppercase tracking-widest text-white"
      >
        {t.legalHeading}
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="font-sans text-sm uppercase tracking-widest text-slate-400 transition-all hover:text-blue-500"
            href={privacyPath(locale)}>{t.privacyLink}</a
          >
        </li>
      </ul>
      <p
        class="mt-12 font-sans text-[10px] uppercase tracking-[0.2em] text-slate-500"
      >
        © {new Date().getFullYear()}
        {siteName}. {t.copyrightRest}
      </p>
      {
        cofepris && (
          <p class="mt-6 font-sans text-xs text-slate-500">
            {t.cofeprisLabel} <strong class="text-slate-400">{cofepris}</strong>
          </p>
        )
      }
    </div>
  </div>
  <div class="h-px w-full bg-slate-800 opacity-30"></div>
</footer>
