---
import DigoeHeader from '../../components/digoe/DigoeHeader.astro';
import PrivacyPolicyContentEn from '../../components/PrivacyPolicyContentEn.astro';
import Layout from '../../layouts/Layout.astro';
import { getMessages } from '../../i18n';

const locale = 'en' as const;
const meta = getMessages(locale).meta;
---

<Layout
  locale={locale}
  page="privacy"
  title={meta.privacyTitle}
  description={meta.privacyDescription}
  ogImagePath="/digoe-hero.webp"
  preloadImage={null}
>
  <DigoeHeader locale={locale} page="privacy" />
  <section id="privacy-policy" class="pt-20">
    <PrivacyPolicyContentEn />
  </section>
</Layout>
